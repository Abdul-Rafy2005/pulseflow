# PulseFlow — Required environment variables
# Copy this file to .env and fill in real values. Never commit .env to git.

# ── Database ────────────────────────────────────────────────
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/pulseflow
SPRING_DATASOURCE_USERNAME=pulseflow
SPRING_DATASOURCE_PASSWORD=pulseflow

# ── RabbitMQ ─────────────────────────────────────────────────
SPRING_RABBITMQ_HOST=localhost
SPRING_RABBITMQ_PORT=5672
SPRING_RABBITMQ_USERNAME=guest
SPRING_RABBITMQ_PASSWORD=guest

# ── Redis ────────────────────────────────────────────────────
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379

# ── Auth ─────────────────────────────────────────────────────
# Must be at least 32 bytes for HS256
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-bytes
JWT_EXPIRATION=PT24H

# ── Events API key (Phase 3) ─────────────────────────────────
# Client applications must send this in the X-API-Key header when POSTing events
EVENTS_API_KEY=change-me-to-a-random-secret-api-key

# ── Events rate limiting (Phase 9) ───────────────────────────
# Max POST /events requests per window per API key (or IP if key missing)
EVENTS_RATE_LIMIT_MAX=100
EVENTS_RATE_LIMIT_WINDOW_SECONDS=60

# ── Server ───────────────────────────────────────────────────
SERVER_PORT=8080
